                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/bookings/{{booking_ref}}/checkout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "bookings",
                "{{booking_ref}}",
                "checkout"
              ]
            }
          },
          "response": []
        }
      ]
    }
